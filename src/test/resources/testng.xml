<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Selenium-TestNG-Framework-Suite"
       verbose="1"
       parallel="classes"
       thread-count="3"
       data-provider-thread-count="2">

    <!-- removed browser parameter, now driven by config.properties -->

    <listeners>
        <listener class-name="Listeners.ExtentReportListener"/>
    </listeners>

    <test name="Login Tests" preserve-order="true">
        <classes>
            <class name="tests.LoginTest"/>
        </classes>
    </test>

    <test name="Product Tests" preserve-order="true">
        <classes>
            <class name="tests.ProductTest"/>
        </classes>
    </test>

    <test name="Checkout Tests" preserve-order="true">
        <classes>
            <class name="tests.CheckoutTest"/>
        </classes>
    </test>

</suite>